# ==============================================================================
# SaaSWpp - ARQUIVO DE CONFIGURAÇÃO CENTRALIZADO (.env)
# ==============================================================================
# Instruções:
# 1. Copie as variáveis relevantes para o painel 'Environmental Variables' do Coolify.
# 2. O Servidor A (Cérebro) precisa de quase todas.
# 3. O Servidor B (Trabalhador) precisa apenas do bloco 'SERVIDOR B'.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🌍 GLOBAIS (Obrigatório em ambos os servidores)
# ------------------------------------------------------------------------------
NODE_ENV=production
APP_URL=https://seu-dominio-principal.com
PORT=3000

# ------------------------------------------------------------------------------
# 🧠 SERVIDOR A - CÉREBRO (App, API, DB, n8n)
# Localização: /deploy/servidor-a-cerebro/
# ------------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
POSTGRES_USER=saas_admin
POSTGRES_PASSWORD=strong_password_123
POSTGRES_DB=saaswpp_db
DATABASE_URL=postgresql://saas_admin:strong_password_123@localhost:5432/saaswpp_db

# Segurança & JWT
JWT_SECRET=super_secret_jwt_key_change_me

# n8n (Automações)
N8N_ENCRYPTION_KEY=n8n_secret_key_123
N8N_USER_MANAGEMENT_JWT_SECRET=n8n_jwt_secret_456

# Pagamentos (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLIC_KEY=

# ------------------------------------------------------------------------------
# 👷 SERVIDOR B - TRABALHADOR (Evolution API, Redis)
# Localização: /deploy/servidor-b-trabalhador/
# ------------------------------------------------------------------------------
# IMPORTANTE: No Servidor A, use o IP LOCAL do Servidor B (Ex: 192.168.88.6)
EVOLUTION_API_URL=http://192.168.88.6:8080
EVOLUTION_API_KEY=global_evolution_key_789
EVOLUTION_API_PORT=8080

# Redis (Cache e Filas)
REDIS_HOST=192.168.88.6
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass_321

# ------------------------------------------------------------------------------
# 🤖 INTELIGÊNCIA ARTIFICIAL (Pool Universal)
# ------------------------------------------------------------------------------
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
